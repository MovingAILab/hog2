@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find SFML if hog2 was built with the SFML backend
set(HOG2_GUI_SFML @HOG2_GUI_SFML@)
if(HOG2_GUI_SFML)
    find_dependency(SFML 3 COMPONENTS Graphics Window System)
    find_dependency(OpenGL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/hog2Targets.cmake")

check_required_components(hog2)
