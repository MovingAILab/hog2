@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Re-find SFML/OpenGL in case the consumer links hog2::hog2-sfml
set(HOG2_SFML_BUILT @HOG2_SFML_BUILT@)
if(HOG2_SFML_BUILT)
    find_dependency(SFML 3 COMPONENTS Graphics Window System)
    find_dependency(OpenGL)
endif()

include("${CMAKE_CURRENT_LIST_DIR}/hog2Targets.cmake")

check_required_components(hog2)
